website:
  title: "photog.jp"
  description: "Nick's photo galleries."
  base_url: "https://photog.jp"
  subtitle: |
    <a href='https://root.wtf'>bio</a>
    <a href='https://baka.jp'>blog</a>
    <a href='https://bsky.app/profile/nkavassalis.bsky.social'>social</a>
    <a href='mailto:nick@photog.jp'>email</a>
  footer: |
    (c) Nick Kavassalis <script>document.write(new Date().getFullYear())</script>
  galleries_per_page: 12
  related_galleries_per_tag: 5

aws:
  s3_bucket: "your-bucket-name"
  cloudfront_dist_id: "your-distribution-id"

editor:
  host: 127.0.0.1
  port: 5001

images:
  # Editor + build cap: each uploaded photo is downscaled so its width
  # is at most max_width (aspect preserved, no height cap), saved as
  # JPEG at display_quality with EXIF orientation applied and a small
  # unsharp mask after resize.
  max_width: 3000
  max_height: 3000
  display_quality: 80
  # Thumbnail (gallery grid) size and quality.
  thumb_width: 480
  thumb_height: 480
  thumb_quality: 80
